# =============================================================================
# BachelorPad — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# Server
PORT=8080
ENV=development                 # development | production

# Database (PostgreSQL 16+ with PostGIS and pgvector)
DATABASE_URL=postgres://user:password@localhost:5432/bachelorpaddb?sslmode=disable

# JWT (HS256)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# AES-256 Encryption for PII fields (phone, Aadhaar, PAN)
# Must be exactly 64 hex characters (= 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Google Maps API (for geocoding on property creation)
GOOGLE_MAPS_API_KEY=

# OpenAI API (for async personality embedding generation)
OPENAI_API_KEY=

# Razorpay (Module 8 — Payments)
# Get test keys from: https://dashboard.razorpay.com (test mode)
# Test keys start with: rzp_test_
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret: set in Razorpay Dashboard > Webhooks > Secret
RAZORPAY_WEBHOOK_SECRET=

# Payments Feature Toggle
# Set to 'true' ONLY in production with valid Razorpay keys.
# When 'false', payment endpoints return a SERVICE_UNAVAILABLE error gracefully.
PAYMENTS_ENABLED=false

# Email / SMTP (wired in Module 10 — leave blank for now)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=noreply@bachelorpad.in
